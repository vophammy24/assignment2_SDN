<!DOCTYPE html>
<html>
<head>
  <title><%= title %></title>

  <style>
    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: linear-gradient(135deg, #e3f2fd, #f8fbff);
      color: #1f2937;
    }

    .page {
      min-height: 100vh;
      padding: 40px;
    }

    .container {
      max-width: 1100px;
      margin: 0 auto;
    }

    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 28px;
    }

    .title-group h1 {
      margin: 0;
      font-size: 34px;
      color: #0f172a;
    }

    .title-group p {
      margin: 8px 0 0;
      color: #64748b;
      font-size: 15px;
    }

    .btn {
      border: none;
      border-radius: 10px;
      padding: 10px 16px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      transition: 0.2s;
    }

    .btn-primary {
      background-color: #2563eb;
      color: white;
      box-shadow: 0 8px 16px rgba(37, 99, 235, 0.2);
    }

    .btn-primary:hover {
      background-color: #1d4ed8;
      transform: translateY(-1px);
    }

    .btn-warning {
      background-color: #f59e0b;
      color: white;
    }

    .btn-warning:hover {
      background-color: #d97706;
    }

    .btn-danger {
      background-color: #ef4444;
      color: white;
    }

    .btn-danger:hover {
      background-color: #dc2626;
    }

    .card {
      background-color: white;
      border-radius: 18px;
      box-shadow: 0 20px 40px rgba(15, 23, 42, 0.08);
      overflow: hidden;
      border: 1px solid #e5e7eb;
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    thead {
      background-color: #f8fafc;
    }

    th {
      text-align: left;
      padding: 16px;
      color: #475569;
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      border-bottom: 1px solid #e5e7eb;
    }

    td {
      padding: 16px;
      border-bottom: 1px solid #f1f5f9;
      font-size: 14px;
      vertical-align: middle;
    }

    tr:hover {
      background-color: #f8fafc;
    }

    .room-badge {
      display: inline-block;
      background-color: #dbeafe;
      color: #1d4ed8;
      padding: 6px 10px;
      border-radius: 999px;
      font-weight: 700;
      font-size: 13px;
    }

    .money {
      font-weight: 700;
      color: #16a34a;
    }

    .actions {
      display: flex;
      gap: 8px;
    }

    .actions form {
      margin: 0;
    }

    .empty {
      padding: 40px;
      text-align: center;
      color: #64748b;
    }

    .footer-action {
      margin-top: 24px;
      text-align: right;
    }

    @media (max-width: 800px) {
      .page {
        padding: 20px;
      }

      .header {
        flex-direction: column;
        align-items: flex-start;
        gap: 16px;
      }

      table {
        min-width: 850px;
      }

      .card {
        overflow-x: auto;
      }
    }
  </style>
</head>

<body>
  <div class="page">
    <div class="container">
      <div class="header">

        <a href="/orders/new" class="btn btn-primary">+ Create New Order</a>
      </div>

      <div class="card">
        <table>
          <thead>
            <tr>
              <th>Customer Name</th>
              <th>Product Name</th>
              <th>Quantity</th>
              <th>Order Date</th>
              <th>Total Price</th>
              <th>Actions</th>
            </tr>
          </thead>

          <tbody>
            <% if (orders.length === 0) { %>
              <tr>
                <td colspan="6" class="empty">
                  No orders found. Click "Create New Order" to create the first Order.
                </td>
              </tr>
            <% } %>

            <% orders.forEach((order) => { %>
              <tr>
                <td>
                  <strong><%= order.customerName %></strong>
                </td>

                <td>
                  <strong><%= order.productName %></strong>
                </td>

                <td><%= order.quantity %></td>

                <td><%= new Date(order.orderDate).toLocaleString() %></td>

                <td>
                  <span class="money"><%= order.totalPrice.toLocaleString() %> VND</span>
                </td>

                <td>
                  <div class="actions">
                    <a href="/orders/<%= order._id %>/edit" class="btn btn-warning">
                      Update
                    </a>

                    <form
                      action="/orders/<%= order._id %>/delete"
                      method="POST"
                      onsubmit="return confirm('Are you sure you want to delete this order?')"
                    >
                      <button type="submit" class="btn btn-danger">
                        Delete
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</body>
</html>