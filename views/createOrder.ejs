<!DOCTYPE html>
<html>
<head>
  <title><%= title %></title>

  <style>
    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: linear-gradient(135deg, #dbeafe, #f8fafc);
      color: #0f172a;
    }

    .page {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 32px;
    }

    .form-card {
      width: 100%;
      max-width: 620px;
      background-color: white;
      border-radius: 22px;
      padding: 34px;
      box-shadow: 0 25px 50px rgba(15, 23, 42, 0.12);
      border: 1px solid #e5e7eb;
    }

    .form-header {
      text-align: center;
      margin-bottom: 28px;
    }

    .icon-circle {
      width: 62px;
      height: 62px;
      border-radius: 50%;
      background-color: #dbeafe;
      color: #2563eb;
      margin: 0 auto 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 28px;
    }

    h1 {
      margin: 0;
      font-size: 30px;
      color: #0f172a;
    }

    .subtitle {
      margin-top: 8px;
      color: #64748b;
      font-size: 14px;
    }

    .error {
      background-color: #fef2f2;
      color: #b91c1c;
      border: 1px solid #fecaca;
      padding: 12px 14px;
      border-radius: 12px;
      margin-bottom: 18px;
      font-size: 14px;
      font-weight: 600;
    }

    .form-group {
      margin-bottom: 18px;
    }

    label {
      display: block;
      margin-bottom: 7px;
      color: #334155;
      font-size: 14px;
      font-weight: 700;
    }

    input,
    select {
      width: 100%;
      height: 46px;
      border: 1px solid #cbd5e1;
      border-radius: 12px;
      padding: 0 14px;
      font-size: 14px;
      outline: none;
      background-color: #f8fafc;
      transition: 0.2s;
    }

    input:focus,
    select:focus {
      border-color: #2563eb;
      background-color: white;
      box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.12);
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }

    .btn {
      width: 100%;
      height: 48px;
      border: none;
      border-radius: 12px;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
      text-decoration: none;
      display: flex;
      justify-content: center;
      align-items: center;
      transition: 0.2s;
    }

    .btn-primary {
      background-color: #2563eb;
      color: white;
      box-shadow: 0 10px 18px rgba(37, 99, 235, 0.25);
      margin-top: 8px;
    }

    .btn-primary:hover {
      background-color: #1d4ed8;
      transform: translateY(-1px);
    }

    .btn-back {
      background-color: #f1f5f9;
      color: #334155;
      margin-top: 12px;
    }

    .btn-back:hover {
      background-color: #e2e8f0;
    }

    @media (max-width: 640px) {
      .form-row {
        grid-template-columns: 1fr;
      }

      .form-card {
        padding: 24px;
      }
    }
  </style>
</head>

<body>
  <div class="page">
    <div class="form-card">
      <div class="form-header">
        <div class="icon-circle">🍀</div>
        <h1>Create New Order</h1>
        <div class="subtitle">Choose an product and enter order time.</div>
      </div>

    <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>

      <form action="/orders" method="POST">
        <div class="form-group">
          <label>Customer Name</label>
          <input
            type="text"
            name="customerName"
            placeholder="Example: Nguyen Van A"
            required
          />
        </div>

        <div class="form-group">
          <label>Product Name</label>
          <select name="productName" required>
            <option value="">Select a product</option>

            <% products.forEach(function(product) { %>
              <option value="<%= product.productName %>">
                 <%= product.productName %>
              </option>
            <% }) %>
          </select>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label>Quantity</label>
            <input
                type="text"
                name="quantity"
                placeholder="1"
                required
            />
            </div>

          <div class="form-group">
            <label>Order Date</label>
            <input type="datetime-local" name="orderDate" required />
          </div>
        </div>

        <button type="submit" class="btn btn-primary">
          Place Order
        </button>

        <a href="/orders" class="btn btn-back">
          Go Back
        </a>
      </form>
    </div>
  </div>
</body>
</html>